<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
  <div class="app-container">
    <nav class="sidebar">
      <h3>Categories</h3>
      <ul>
        <% sidebarCategories.forEach(cat => { %>
          <li>
            <a href="/categories/<%= cat.id %>">
              <%= cat.name %>
              <% if (cat.hasAlert) { %>
                <span class="alert-dot" title="Low stock items detected!">●</span>
              <% } %>
            </a>
          </li>
        <% }) %>
      </ul>
      <h3>Inventory Actions</h3>
      <ul class="actions-list">
        <li><a href="/products/new" class="btn-add">+ Add New Product</a></li>
        <li><a href="/ingredients/new" class="btn-add">+ Add New Ingredient</a></li>
        <li><a href="/categories/new" class="btn-add">+ Add New Category</a></li>
      </ul>
    </nav>
    <main class="content">