<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
  <input type="checkbox" id="menu-toggle" class="menu-checkbox">
  <label for="menu-toggle" class="hamburger">
    <span></span> <!-- The 3 bars of the hamburger -->
  </label>
  <div class="app-container">
    <nav class="sidebar">
      <a href="/" class="btn-category dashboard-btn <%= locals.activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <h2 class="header-name">Categories</h2>
      <ul class="categories-list">
        <% if (sidebarCategories && sidebarCategories.length > 0) { %>
          <% sidebarCategories.forEach(cat => { %>
            <li>
              <a href="/categories/<%= cat.id %>" class="btn-category <%= (locals.currentCategoryId == cat.id) ? 'active' : '' %>">
                <%= cat.name %>
              </a>
              <% if (cat.hasAlert) { %>
                <span class="alert-dot" title="Low stock items detected!">●</span>
              <% } %>
            </li>
          <% }) %>
        <% } else { %>
          <li class="no-categories">There are no categories</li>
        <% } %>
      </ul>
      <h2 class="header-name">Inventory Actions</h2>
      <ul class="actions-list">
        <li><a href="/products/new" class="btn-sidebar">+ Add New Product</a></li>
        <li><a href="/ingredients/new" class="btn-sidebar">+ Add New Ingredient</a></li>
        <li><a href="/categories/new" class="btn-sidebar">+ Add New Category</a></li>
        <li><a href="/suppliers/new" class="btn-sidebar">+ Add New Supplier</a></li>
        <li><a href="/suppliers" class="btn-category <%= locals.activePage === 'suppliers' ? 'active' : '' %>">View All Suppliers</a></li>
        <li><a href="/transactions" class="btn-category <%= locals.activePage === 'transactions' ? 'active' : '' %>">View Transaction History</a></li>

      </ul>
    </nav>
    <label for="menu-toggle" class="menu-overlay"></label>
    <main class="content">