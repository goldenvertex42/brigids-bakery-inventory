<%- include('partials/header') %>

<h1>
  <%= title %>
</h1>

<form action="<%= locals.supplier ? '/suppliers/' + supplier.id + '/edit' : '/suppliers/new' %>" method="POST">
  <%- include('partials/error') %>
  
  <div class="form-group">
    <label for="name">Supplier Name:</label>
    <input type="text" id="name" name="name" value="<%= locals.formData ? formData.name : (locals.supplier ? supplier.name : '') %>" required>
  </div>

  <div class="form-group">
    <label for="contact_name">Contact Name:</label>
    <input type="text" id="contact_name" name="contact_name" value="<%= locals.formData ? formData.contact_name : (locals.supplier ? supplier.contact_name : '') %>" required>
  </div>

  <div class="form-group">
    <label for="email">Email:</label>
    <input type="email" id="email" name="email" value="<%= locals.formData ? formData.email : (locals.supplier ? supplier.email : '') %>" required>
  </div>

  <div class="form-group">
    <label for="phone">Phone Number:</label>
    <input type="tel" id="phone" name="phone" value="<%= locals.formData ? formData.phone : (locals.supplier ? supplier.phone : '') %>" required>
  </div>

  <div class="form-group">
    <label for="address">Address:</label>
    <input type="text" id="address" name="address" value="<%= locals.formData ? formData.address : (locals.supplier ? supplier.address : '') %>">
  </div>

  <button type="submit" class="btn-submit">
    <%= locals.supplier ? 'Update Supplier' : 'Create Supplier' %>
  </button>
</form>
<% if (locals.supplier) { %>
  <hr>
  <section class="danger-zone">
    <h2>Danger Zone</h2>
    <p>To delete this supplier, enter the admin password and click Delete.</p>
    
    <form action="/suppliers/<%= supplier.id %>/delete" method="POST">
      <div class="form-group">
        <input type="password" name="admin_password" placeholder="Admin Password" required>
      </div>
      <button type="submit" class="btn-delete">Delete Supplier Permanently</button>
    </form>
  </section>
<% } %>
<%- include('partials/footer') %>
