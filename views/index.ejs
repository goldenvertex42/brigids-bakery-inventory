<%- include('./partials/header') %>

<main class="dashboard-container">
  <h1>Inventory Overview</h1>

  <div class="dashboard-grid">
    
    <!-- Widget 1: Low Stock Alerts (Combined) -->
    <section class="card <% lowStockProducts || lowStockIngredients ? "alert-card" : ""%>">
      <h2>⚠️ Low Stock Alerts</h2>
      <ul>
        <% [...lowStockProducts, ...lowStockIngredients].forEach(item => { %>
          <li>
            <span><%= item.name %></span>
            <span class="stock-count"><%= item.quantity_on_hand %> left</span>
          </li>
        <% }) %>
        <% if (lowStockProducts.length === 0 && lowStockIngredients.length === 0) { %>
          <li class="empty">All stock levels healthy!</li>
        <% } %>
      </ul>
    </section>

    <!-- Widget 2: Top Sellers -->
    <section class="card">
      <h2>🏆 Top 5 Sellers</h2>
      <ol>
        <% topSellers.forEach(product => { %>
          <li>
            <%= product.name %> 
            <span class="stat-value"><%= Math.abs(product.total_sold) %> units</span>
          </li>
        <% }) %>
      </ol>
    </section>

    <!-- Widget 3: Waste Report -->
    <section class="card">
      <h2>📉 Recent Waste</h2>
      <ul>
        <% wasteReport.forEach(item => { %>
          <li>
            <%= item.item_name %>
            <span class="stat-value text-danger"><%= Math.abs(item.total_wasted) %> lost</span>
          </li>
        <% }) %>
        <% if (wasteReport.length === 0) { %>
          <li class="empty">No waste recorded.</li>
        <% } %>
      </ul>
    </section>

  </div>
</main>

<%- include('./partials/footer') %>

