<%- include('./partials/header') %>

<main class="transaction-container">
  <header class="page-header">
    <h1>Transaction History</h1>
    <a href="/transactions/new" class="btn-edit">+ New Transaction</a>
  </header>

  <section class="table-wrapper">
    <table class="audit-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Item</th>
          <th>Type</th>
          <th>Quantity</th>
          <th>Source / Supplier</th> 
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% if (transactions.length > 0) { %>
          <% transactions.forEach(t => { %>
            <tr>
              <!-- Short Date Formatting -->
              <td><%= new Date(t.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
              
              <!-- Item Name (Product or Ingredient) -->
              <td><strong><%= t.product_name || t.ingredient_name %></strong></td>
              
              <!-- Type Badge -->
              <td>
                <span class="status-badge badge-<%= t.type %>">
                  <%= t.type %>
                </span>
              </td>
              
              <!-- Quantity Logic -->
              <td class="qty-column <%= t.quantity < 0 ? 'neg' : 'pos' %>">
                <%= t.quantity > 0 ? '+' : '' %><%= t.quantity %>
              </td>
              <td>
                <%= t.supplier_name ? t.supplier_name : '-' %>
              </td>
              <td class="description-cell"><%= t.description %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" class="no-data">No transactions found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </section>
</main>

<%- include('./partials/footer') %>
